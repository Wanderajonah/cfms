PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/cfms
JWT_SECRET=replace_with_a_long_random_secret

# SMS (Comms / egosms) — no space after =
COMMS_ENDPOINT=https://comms.egosms.co/api/v1/json/
COMMS_USERNAME=your_api_username
COMMS_API_KEY=your_api_key
COMMS_SENDER_ID=MyCompany

# AI auto-reply SMS (Groq) — create a key at https://console.groq.com/keys
# IMPORTANT: no space after = (e.g. GROQ_API_KEY=gsk_...)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
AI_BRAND_NAME=FeedbackHub

# Turn on automated SMS after each feedback (retries for ~2 minutes)
AUTO_AI_SMS_ENABLED=true
# Set true to skip auto-SMS only for complaints (human handles them)
AUTO_AI_SMS_SKIP_COMPLAINTS=false
# Legacy: if set to false, complaints never get auto-SMS (same as skip)
AUTO_AI_SMS_COMPLAINTS=true
# If Groq fails on last retry, send a short generic SMS instead
AUTO_AI_SMS_FALLBACK=true
